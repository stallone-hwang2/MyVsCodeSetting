            "encrypt": "Mandatory",
            "groupId": "ROOT",
            "profileName": "192.168.2.244",
            "savePassword": true,
            "trustServerCertificate": true,
            "id": "d4d0310b-aa9b-47ad-b6ed-c5d7943fadf2"
        }
    ]
}